# =============================================================================
# BANCO DE DADOS (Vercel Postgres / Neon)
# Copie os valores do painel da Vercel em: Storage > seu-banco > .env.local
# =============================================================================
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# =============================================================================
# AUTENTICAÇÃO GOOGLE (Google Cloud Console)
# https://console.cloud.google.com/apis/credentials
# =============================================================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Domínio permitido para login (ex: "suaempresa.com"). Deixe vazio para permitir qualquer conta Google.
GOOGLE_ALLOWED_DOMAIN=""

# =============================================================================
# APLICAÇÃO
# =============================================================================
NEXT_PUBLIC_BASE_URL="https://seu-projeto.vercel.app"

# =============================================================================
# INTELIGÊNCIA ARTIFICIAL
# Provider de IA: "mock" (padrão, sem custo), "openai" ou "anthropic"
# =============================================================================
AI_PROVIDER="mock"

# Se usar OpenAI
OPENAI_API_KEY=""

# Se usar Anthropic
ANTHROPIC_API_KEY=""
